# Copy to .env (local) or set as Railway service env vars.
# .env is gitignored — never commit secrets.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/master_paper_trade_lab

# ---------------------------------------------------------------------------
# Polymarket — public APIs, no auth needed for read-only
# ---------------------------------------------------------------------------
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com

# Optional: API JWT for higher rate limits on data feeds (read-only)
POLYMARKET_API_TOKEN=

# ---------------------------------------------------------------------------
# Tier 3 calibration (off by default — must also flip runtime.yaml)
# ---------------------------------------------------------------------------
# When/if enabled: EOA private key used to sign tiny shadow orders.
# DO NOT commit. Recommend Railway encrypted env var only.
CALIBRATION_WALLET_PRIVATE_KEY=
CALIBRATION_WALLET_ADDRESS=

# ---------------------------------------------------------------------------
# Reddit — only needed if pipes.yaml enables reddit
# ---------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=master-paper-trade-lab/0.1 (by u/elmorshedydel)

# ---------------------------------------------------------------------------
# Kalshi — public market data API (read-only)
# ---------------------------------------------------------------------------
KALSHI_API_BASE=https://trading-api.kalshi.com/trade-api/v2

# ---------------------------------------------------------------------------
# Deribit options — public WS
# ---------------------------------------------------------------------------
DERIBIT_WS_URL=wss://www.deribit.com/ws/api/v2/

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
